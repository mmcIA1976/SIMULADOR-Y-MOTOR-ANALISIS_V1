APP_ENV=development
DATABASE_URL=sqlite:///data/trading_trainer.db
# En servidor usar solo Supabase:
# APP_ENV=production
# SUPABASE_DATABASE_URL=postgresql://USER:PASS@HOST:5432/postgres
TRADING_TRAINER_SECRET=change-me-before-production

# Mapa gratuito de posiciones/liquidaciones publicas de Hyperliquid.
HYPERPERPS_ENABLED=true
HYPERPERPS_TIMEOUT_SECONDS=4
HYPERPERPS_CACHE_TTL_SECONDS=60
HYPERPERPS_MAX_AGE_SECONDS=600
HYPERPERPS_MAX_PRICE_BASIS_PCT=1.5
